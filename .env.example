# --- Core ---
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-prod

# --- URLs / CORS ---
APP_URL=http://localhost:5173
API_URL=http://localhost:8008
PUBLIC_URL=http://localhost:8008           # serves /c/{slug} in dev
COOKIE_DOMAIN=localhost
CORS_ORIGINS=http://localhost:5173

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=easycred
POSTGRES_USER=easycred
POSTGRES_PASSWORD=easycred
DATABASE_URL=postgresql+psycopg://easycred:easycred@localhost:5432/easycred

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (MinIO in dev) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=easycred-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
CDN_BASE_URL=http://localhost:9000/easycred-dev
MEDIA_ROOT=./backend/media
FRONTEND_DIST_DIR=./frontend/dist

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- OAuth: Facebook ---
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- OAuth: Apple (Sign in with Apple) ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- OAuth: GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- AI providers ---
OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# --- Email ---
EMAIL_PROVIDER=resend                       # or 'ses'
RESEND_API_KEY=
EMAIL_FROM=notifications@send.easylearning.ai

# --- Pricing (cents) ---
CREDENTIAL_PRICE_CENTS=399

# --- Signing keys (dev only; prod uses KMS) ---
SIGNING_KEY_PEM_PATH=./signing-key.pem
